root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# Kotlin files
[*.{kt,kts}]
max_line_length = 120
indent_size = 4
ij_kotlin_code_style_defaults = KOTLIN_OFFICIAL

# ktlint specific rules
ktlint_code_style = ktlint_official
ktlint_standard = enabled
ktlint_experimental = disabled

# Wildcard imports
ktlint_standard_no-wildcard-imports = enabled

# Compose-specific: Allow function names starting with uppercase for @Composable
ktlint_function_naming_ignore_when_annotated_with = Composable

# Disable ktlint for generated/build files
[**/build/**]
ktlint = disabled

[**/generated/**]
ktlint = disabled

# Gradle files
[*.gradle.kts]
indent_size = 4

# XML files (Android resources)
[*.xml]
indent_size = 4

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
max_line_length = off
trim_trailing_whitespace = false

# Properties files
[*.properties]
charset = utf-8
